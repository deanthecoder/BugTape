<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ic="using:FluentIcons.Avalonia"
        xmlns:vm="using:BugTape.Viewer.ViewModels"
        xmlns:models="using:BugTape.Viewer.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="780"
        x:Class="BugTape.Viewer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1280"
        Height="780"
        MinWidth="980"
        MinHeight="640"
        Icon="/Assets/BugTape.png"
        Title="BugTape Viewer">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,150,*,28" Background="#f3f4f6">
        <Border Grid.Row="0" Background="#ffffff" BorderBrush="#d1d5db" BorderThickness="0,0,0,1" Padding="14,12">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                <TextBlock Grid.Column="0"
                           Text="BugTape"
                           Foreground="#111827"
                           FontSize="20"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <TextBox Grid.Column="1"
                         Text="{Binding PackagePath}"
                         Watermark="Unzipped support package folder"
                         IsReadOnly="True"
                         Background="#ffffff"
                         Foreground="#111827"
                         BorderBrush="#9ca3af"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="2"
                        Click="OnOpenFolderClicked"
                        ToolTip.Tip="Open an unzipped BugTape support package folder"
                        Background="#f9fafb"
                        Foreground="#111827"
                        BorderBrush="#9ca3af"
                        Padding="10,7">
                    <ic:FluentIcon Icon="FolderOpen"
                                   IconVariant="Regular"
                                   IconSize="Size24"
                                   Foreground="#374151"/>
                </Button>
                <Button Grid.Column="3"
                        Click="OnOpenZipClicked"
                        ToolTip.Tip="Open a .zip file containing BugTape support package files"
                        Background="#f9fafb"
                        Foreground="#111827"
                        BorderBrush="#9ca3af"
                        Padding="10,7">
                    <ic:FluentIcon Icon="ArchiveMultiple"
                                   IconVariant="Regular"
                                   IconSize="Size24"
                                   Foreground="#374151"/>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="2*,*" Margin="14,12,14,8" ColumnSpacing="12">
            <Border Grid.Column="0" Background="#ffffff" BorderBrush="#d7dce2" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="Session" FontWeight="SemiBold" Foreground="#222831"/>
                    <TextBlock Text="{Binding ManifestSummary}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#3f4652"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#ffffff" BorderBrush="#d7dce2" BorderThickness="1" CornerRadius="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="Application Snapshot" FontWeight="SemiBold" Foreground="#222831"/>
                    <TextBlock Text="{Binding StateSummary}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#3f4652"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Margin="14,0,14,8" Background="#ffffff" BorderBrush="#d7dce2" BorderThickness="1" CornerRadius="4">
            <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,Auto" Margin="12,10,12,4" ColumnSpacing="12">
                    <TextBlock Text="Timeline" FontWeight="SemiBold" Foreground="#222831"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding SelectedMetricSummary}"
                               Foreground="#69707d"
                               FontSize="12"
                               VerticalAlignment="Center"/>
                    <ItemsControl Grid.Column="2"
                                  ItemsSource="{Binding MetricOptions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Tag="{Binding Key}"
                                        Click="OnMetricOverlayClicked"
                                        ToolTip.Tip="{Binding Label}"
                                        Padding="7,4"
                                        MinWidth="30"
                                        Background="#f9fafb"
                                        BorderBrush="#d1d5db"
                                        Foreground="#222831">
                                    <Viewbox Width="18" Height="18">
                                        <Path Width="24"
                                              Height="24"
                                              Stretch="Uniform"
                                              Fill="{Binding Brush}"
                                              Data="{Binding IconPath}"/>
                                    </Viewbox>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="BugTape logs" Foreground="#805ad5"/>
                        <TextBlock Text="actions" Foreground="#2563eb"/>
                        <TextBlock Text="events" Foreground="#4a5568"/>
                        <TextBlock Text="warnings/errors" Foreground="#c2410c"/>
                    </StackPanel>
                </Grid>
                <ScrollViewer x:Name="TimelineScrollViewer"
                              Grid.Row="1"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              AllowAutoHide="False"
                              Height="108"
                              Margin="12,0,12,12">
                    <Canvas Width="{Binding TimelineWidth}" Height="84" Background="#f8fafc">
                        <Border Canvas.Top="42"
                                Width="{Binding TimelineWidth}"
                                Height="1"
                                Background="#e5e7eb"/>
                        <ItemsControl Canvas.Top="44"
                                      ItemsSource="{Binding SelectedMetricSegments}"
                                      Width="{Binding TimelineWidth}"
                                      Height="40">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding TimelineWidth}" Height="40" Background="Transparent"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line StartPoint="{Binding StartPoint}"
                                          EndPoint="{Binding EndPoint}"
                                          Stroke="{Binding $parent[Window].DataContext.SelectedMetricBrush}"
                                          StrokeThickness="2"
                                          Opacity="0.75"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <ItemsControl ItemsSource="{Binding TimelineTicks}" Width="{Binding TimelineWidth}" Height="84">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding TimelineWidth}" Height="84" Background="Transparent"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="78" Height="84" Margin="-39,0,0,0">
                                        <Border Width="1"
                                                Height="42"
                                                Background="#d1d5db"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Top"/>
                                        <TextBlock Text="{Binding Label}"
                                                   Foreground="#69707d"
                                                   FontFamily="Consolas"
                                                   FontSize="11"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Bottom"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Canvas.Left="{Binding SelectedHighlight.Left}"
                                Width="{Binding SelectedHighlight.Width}"
                                Height="84"
                                Background="#6638bdf8"
                                IsVisible="{Binding SelectedHighlight}"/>
                        <ItemsControl ItemsSource="{Binding TimelineMarkers}" Width="{Binding TimelineWidth}" Height="84">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas Width="{Binding TimelineWidth}" Height="84" Background="Transparent"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding Left}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding Top}"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="{Binding Width}"
                                          Height="{Binding Height}"
                                          ToolTip.Tip="{Binding ToolTip}"
                                          Cursor="Hand"
                                          PointerPressed="OnTimelineMarkerPointerPressed">
                                        <Border Width="{Binding Width}"
                                                Height="{Binding Height}"
                                                Background="{Binding Brush}"
                                                CornerRadius="2"
                                                IsVisible="{Binding IsBar}"/>
                                        <Path Width="{Binding Width}"
                                              Height="{Binding Height}"
                                              Stretch="Fill"
                                              Fill="{Binding Brush}"
                                              Data="M 0,0 L 10,0 L 5,8 Z"
                                              IsVisible="{Binding IsWedge}"/>
                                        <Ellipse Width="{Binding Width}"
                                                 Height="{Binding Height}"
                                                 Fill="#dc2626"
                                                 IsVisible="{Binding IsError}"/>
                                        <TextBlock Text="!"
                                                   Foreground="#ffffff"
                                                   FontSize="10"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-1,0,0"
                                                   IsVisible="{Binding IsError}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Canvas>
                </ScrollViewer>
            </Grid>
        </Border>

        <Grid Grid.Row="3" ColumnDefinitions="3*,6,2*" Margin="14,0,14,8">
            <Border Grid.Column="0" Background="#ffffff" BorderBrush="#d7dce2" BorderThickness="1" CornerRadius="4">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="Timeline Tree" Margin="12,10,12,6" FontWeight="SemiBold" Foreground="#222831"/>
                    <TreeView Grid.Row="1"
                              ItemsSource="{Binding TreeNodes}"
                              SelectionChanged="OnTimelineTreeSelectionChanged"
                              SelectedItem="{Binding SelectedTreeNode, Mode=TwoWay}"
                              Background="#ffffff"
                              Foreground="#222831"
                              Margin="6">
                        <TreeView.Styles>
                            <Style Selector="TreeViewItem">
                                <Setter Property="Background" Value="#ffffff"/>
                                <Setter Property="Foreground" Value="#222831"/>
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            </Style>
                        </TreeView.Styles>
                        <TreeView.DataTemplates>
                            <TreeDataTemplate DataType="models:TimelineTreeNode" ItemsSource="{Binding Children}">
                                <Grid ColumnDefinitions="72,16,220,*" ColumnSpacing="8" Margin="0,3" ToolTip.Tip="{Binding FullText}">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Timestamp}"
                                               Foreground="#69707d"
                                               FontFamily="Consolas"
                                               FontSize="12"/>
                                    <Border Grid.Column="1"
                                            Width="10"
                                            Height="10"
                                            CornerRadius="5"
                                            Background="{Binding Brush}"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Title}"
                                               Foreground="#222831"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="3"
                                               Text="{Binding Detail}"
                                               Foreground="#69707d"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </TreeDataTemplate>
                        </TreeView.DataTemplates>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          Background="#d1d5db"
                          ResizeDirection="Columns"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"/>

            <Border Grid.Column="2" Background="#ffffff" BorderBrush="#d7dce2" BorderThickness="1" CornerRadius="4">
                <TabControl>
                    <TabItem Header="Details">
                        <TreeView ItemsSource="{Binding SelectedJsonNodes}"
                                  Background="#ffffff"
                                  Foreground="#222831"
                                  Margin="8">
                            <TreeView.Styles>
                                <Style Selector="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded}"/>
                                </Style>
                            </TreeView.Styles>
                            <TreeView.DataTemplates>
                                <TreeDataTemplate DataType="models:JsonTreeNode" ItemsSource="{Binding Children}">
                                    <Grid ColumnDefinitions="220,*" ColumnSpacing="8" Margin="0,2" ToolTip.Tip="{Binding FullText}">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Foreground="#222831"
                                                   FontWeight="SemiBold"
                                                   FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Foreground="#69707d"
                                                   FontFamily="Consolas"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                    </TabItem>
                    <TabItem Header="Logs">
                        <TextBox x:Name="LogExcerptTextBox"
                                 Text="{Binding SelectedLogExcerpt}"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Margin="8"/>
                    </TabItem>
                </TabControl>
            </Border>
        </Grid>

        <Border Grid.Row="4" Background="#e7ebf0" Padding="12,5">
            <TextBlock Text="{Binding Status}" Foreground="#3f4652"/>
        </Border>
    </Grid>
</Window>
