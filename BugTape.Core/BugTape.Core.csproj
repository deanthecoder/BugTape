<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <ImplicitUsings>disable</ImplicitUsings>
    <PackageId>BugTape.Core</PackageId>
    <PackageVersion>0.1.0</PackageVersion>
    <Authors>Dean Edis (DeanTheCoder)</Authors>
    <Description>A local-first flight recorder and support-pack toolkit for desktop applications.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageIcon>BugTape.png</PackageIcon>
    <PackageTags>diagnostics;support-pack;desktop;logging;flight-recorder</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
    <None Include="..\LICENSE" Pack="true" PackagePath="\" />
    <None Include="..\img\BugTape.png" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
